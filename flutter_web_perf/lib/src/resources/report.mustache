<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Flutter Web Performance Report</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&family=Roboto+Mono&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-color: #0f172a;
      --card-bg: rgba(30, 41, 59, 0.7);
      --text-color: #f8fafc;
      --accent-color: #38bdf8;
      --secondary-color: #94a3b8;
      --danger-color: #ef4444;
      --success-color: #22c55e;
      --glass-border: rgba(255, 255, 255, 0.1);
    }

    body {
      font-family: 'Outfit', sans-serif;
      background-color: var(--bg-color);
      color: var(--text-color);
      margin: 0;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      min-height: 100vh;
    }

    .container {
      width: 100%;
      max-width: 1000px;
    }

    header {
      text-align: center;
      margin-bottom: 3rem;
    }

    h1 {
      font-weight: 600;
      font-size: 3rem;
      margin-bottom: 0.5rem;
      background: linear-gradient(to right, #38bdf8, #818cf8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    p.subtitle {
      color: var(--secondary-color);
      font-size: 1.2rem;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .card {
      background: var(--card-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      border-radius: 1rem;
      padding: 2rem;
      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
      transition: transform 0.3s ease;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    .card h2 {
      font-size: 1.5rem;
      margin-top: 0;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--glass-border);
      padding-bottom: 0.5rem;
      color: var(--accent-color);
    }

    .metric {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }

    .metric-label {
      color: var(--secondary-color);
    }

    .metric-value {
      font-family: 'Roboto Mono', monospace;
      font-weight: 600;
      font-size: 1.2rem;
    }

    .metric-value.danger {
      color: var(--danger-color);
    }

    .metric-value.success {
      color: var(--success-color);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }

    th, td {
      text-align: left;
      padding: 0.75rem;
      border-bottom: 1px solid var(--glass-border);
      word-wrap: break-word;
      overflow: hidden;
      max-width: 0;
    }

    th {
      color: var(--secondary-color);
      font-weight: 600;
    }

    td.mono {
      font-family: 'Roboto Mono', monospace;
      font-size: 0.9rem;
    }

    .tag {
      display: inline-block;
      padding: 0.25rem 0.5rem;
      border-radius: 0.25rem;
      font-size: 0.8rem;
      font-weight: 600;
      background: rgba(56, 189, 248, 0.2);
      color: var(--accent-color);
    }

    .tag.sdk {
      background: rgba(148, 163, 184, 0.2);
      color: var(--secondary-color);
    }

    .bar-chart {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .bar-item {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .bar-label {
      width: 100px;
      color: var(--secondary-color);
    }

    .bar-container {
      flex-grow: 1;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 0.5rem;
      height: 1rem;
      overflow: hidden;
    }

    .bar {
      height: 100%;
      background: linear-gradient(to right, #38bdf8, #818cf8);
      border-radius: 0.5rem;
    }

    .code-block {
      background: rgba(0, 0, 0, 0.4);
      border-radius: 0.5rem;
      overflow: hidden;
      display: flex;
      font-family: 'Roboto Mono', monospace;
      font-size: 0.85rem;
      border: 1px solid var(--glass-border);
      line-height: 1.5;
    }

    .gutter {
      padding: 1rem 0.5rem;
      background: rgba(255, 255, 255, 0.03);
      border-right: 1px solid var(--glass-border);
      text-align: right;
      color: var(--secondary-color);
      user-select: none;
      min-width: 2.5rem;
    }

    .code-content {
      padding: 1rem;
      overflow-x: auto;
      flex-grow: 1;
      color: #e2e8f0; /* Brighter text */
      white-space: pre;
    }

    footer {
      text-align: center;
      margin-top: 5rem;
      color: var(--secondary-color);
      font-size: 0.9rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Performance Report</h1>
      <p class="subtitle">Flutter Web Application Profiling Results</p>
    </header>

    <div class="grid">
      <!-- Frame Health -->
      <div class="card">
        <h2>Frame Health</h2>
        <div class="metric">
          <span class="metric-label">Average Frame Interval</span>
          <span class="metric-value">{{frameHealth.avgIntervalMs}} ms</span>
        </div>
        <div class="metric">
          <span class="metric-label">Average Frame Work</span>
          <span class="metric-value danger">{{frameHealth.avgWorkMs}} ms</span>
        </div>
        <div class="metric">
          <span class="metric-label">Drop Rate</span>
          <span class="metric-value danger">{{frameHealth.dropRate}}%</span>
        </div>
        <div class="metric">
          <span class="metric-label">Requested Frames</span>
          <span class="metric-value">{{frameHealth.requestedCount}}</span>
        </div>
        <div class="metric">
          <span class="metric-label">Processed Frames</span>
          <span class="metric-value">{{frameHealth.processedCount}}</span>
        </div>
      </div>

      <!-- Time Breakdown -->
      <div class="card">
        <h2>Time Breakdown</h2>
        <div class="bar-chart">
          {{#timeBreakdown}}
          <div class="bar-item">
            <span class="bar-label">{{category}}</span>
            <div class="bar-container">
              <div class="bar" style="width: {{percent}}%"></div>
            </div>
            <span class="metric-value">{{durationMs}} ms</span>
          </div>
          {{/timeBreakdown}}
        </div>
      </div>
    </div>

    <!-- Hot Functions -->
    <div class="card" style="width: 100%;">
      <h2>Top 10 Hot Functions</h2>
      <table>
        <thead>
          <tr>
            <th style="width: 5%;">#</th>
            <th style="width: 45%;">Function</th>
            <th style="width: 40%;">Location</th>
            <th style="width: 10%;">Samples</th>
          </tr>
        </thead>
        <tbody>
          {{#hotFunctions}}
          <tr>
            <td style="{{#hasWasm}}border-bottom: none;{{/hasWasm}}">{{index}}</td>
            <td class="mono" style="{{#hasWasm}}border-bottom: none;{{/hasWasm}}">{{name}}</td>
            <td style="{{#hasWasm}}border-bottom: none;{{/hasWasm}}">
              <span class="{{tagClass}}">{{tagText}}</span> 
              {{#hasGithubUrl}}
              <a href="{{githubUrl}}" target="_blank" style="color: var(--accent-color); text-decoration: none; border-bottom: 1px dashed var(--accent-color);">{{url}}</a>
              {{/hasGithubUrl}}
              {{^hasGithubUrl}}
              {{url}}
              {{/hasGithubUrl}}
            </td>
            <td class="mono" style="{{#hasWasm}}border-bottom: none;{{/hasWasm}}">{{samples}}</td>
          </tr>
          {{#hasWasm}}
          <tr>
            <td></td>
            <td colspan="3" style="padding-top: 0; padding-bottom: 1.5rem;">
              <details style="cursor: pointer;">
                <summary style="color: var(--accent-color); font-size: 0.8rem; margin-bottom: 0.5rem;">View Wasm Instructions</summary>
                <div class="code-block">
                  <div class="gutter">
                    {{#wasmLines}}{{number}}<br>{{/wasmLines}}
                  </div>
                  <div class="code-content">{{#wasmLines}}{{text}}
{{/wasmLines}}</div>
                </div>
              </details>
            </td>
          </tr>
          {{/hasWasm}}
          {{/hotFunctions}}
        </tbody>
      </table>
    </div>

    <footer>
      Generated by flutter_web_perf tool.
    </footer>
  </div>
</body>
</html>
