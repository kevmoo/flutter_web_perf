<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Flutter Web Performance Report</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&family=Roboto+Mono&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-color: #0f172a;
      --card-bg: rgba(30, 41, 59, 0.7);
      --text-color: #f8fafc;
      --accent-color: #38bdf8;
      --secondary-color: #94a3b8;
      --danger-color: #ef4444;
      --success-color: #22c55e;
      --glass-border: rgba(255, 255, 255, 0.1);
    }

    body {
      font-family: 'Outfit', sans-serif;
      background-color: var(--bg-color);
      color: var(--text-color);
      margin: 0;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      min-height: 100vh;
    }

    .container {
      width: 100%;
      max-width: 1000px;
    }

    header {
      text-align: center;
      margin-bottom: 3rem;
    }

    h1 {
      font-weight: 600;
      font-size: 3rem;
      margin-bottom: 0.5rem;
      background: linear-gradient(to right, #38bdf8, #818cf8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    p.subtitle {
      color: var(--secondary-color);
      font-size: 1.2rem;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .card {
      background: var(--card-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      border-radius: 1rem;
      padding: 2rem;
      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
      transition: transform 0.3s ease;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    .card h2 {
      font-size: 1.5rem;
      margin-top: 0;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--glass-border);
      padding-bottom: 0.5rem;
      color: var(--accent-color);
    }

    .metric {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
    }

    .metric-label {
      color: var(--secondary-color);
    }

    .metric-value {
      font-family: 'Roboto Mono', monospace;
      font-weight: 600;
      font-size: 1.2rem;
    }

    .metric-value.danger {
      color: var(--danger-color);
    }

    .metric-value.success {
      color: var(--success-color);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
      table-layout: fixed;
    }

    th, td {
      text-align: left;
      padding: 0.75rem;
      border-bottom: 1px solid var(--glass-border);
      word-wrap: break-word;
    }

    th {
      color: var(--secondary-color);
      font-weight: 600;
    }

    td.mono {
      font-family: 'Roboto Mono', monospace;
      font-size: 0.9rem;
    }

    .tag {
      display: inline-block;
      padding: 0.15rem 0.45rem;
      border-radius: 0.25rem;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border: 1px solid currentColor;
      background: transparent;
      box-shadow: 0 0 4px currentColor;
      margin-right: 0.5rem;
      vertical-align: middle;
    }

    .tag.flutterBuild {
      color: #10b981; /* Glowing Emerald (Build) */
    }

    .tag.flutterLayout {
      color: #f59e0b; /* Glowing Amber (Layout) */
    }

    .tag.flutterPaint {
      color: #ec4899; /* Glowing Pink (Paint) */
    }

    .tag.flutterCompositing {
      color: #a855f7; /* Glowing Purple (Compositing) */
    }

    .tag.engineRaster {
      color: #06b6d4; /* Glowing Cyan (Raster) */
    }

    .tag.jsScripting, .tag.other {
      color: #3b82f6; /* Glowing Blue (Script) */
    }

    .bar-chart {
      display: grid;
      grid-template-columns: 160px 1fr 180px;
      gap: 0.8rem 1.5rem;
      align-items: center;
    }

    @media (max-width: 768px) {
      .bar-chart {
        grid-template-columns: 1fr;
        gap: 0.5rem;
      }
      .bar-label {
        margin-top: 0.5rem;
      }
    }

    .bar-label {
      color: var(--secondary-color);
      font-size: 0.9rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .bar-container {
      width: 100%;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 0.5rem;
      height: 0.8rem;
      overflow: hidden;
      box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.3);
    }

    .bar {
      height: 100%;
      background: linear-gradient(to right, #38bdf8, #818cf8);
      border-radius: 0.5rem;
      box-shadow: 0 0 6px rgba(56, 189, 248, 0.3);
      display: flex;
      align-items: center;
      justify-content: flex-start;
      padding-left: 0.75rem;
      box-sizing: border-box;
    }

    .bar-percent {
      font-size: 0.95rem;
      font-weight: bold;
      color: #0a0f1d;
      pointer-events: none;
    }

    .bar-chart .metric-value {
      text-align: right;
      font-size: 0.95rem;
      color: var(--text-color);
    }

    .code-block {
      background: rgba(0, 0, 0, 0.4);
      border-radius: 0.5rem;
      overflow: hidden;
      display: flex;
      font-family: 'Roboto Mono', monospace;
      font-size: 0.85rem;
      border: 1px solid var(--glass-border);
      line-height: 1.5;
    }

    .gutter {
      padding: 1rem 0.5rem;
      background: rgba(255, 255, 255, 0.03);
      border-right: 1px solid var(--glass-border);
      text-align: right;
      color: var(--secondary-color);
      user-select: none;
      min-width: 2.5rem;
    }

    .code-content {
      padding: 1rem;
      overflow-x: auto;
      flex-grow: 1;
      color: #ffffff; /* Brighter text */
      white-space: pre;
    }

    .tab-btn {
      background: none;
      border: none;
      color: var(--secondary-color);
      font-family: 'Outfit', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      padding: 0.5rem 1rem;
      border-radius: 0.25rem;
      transition: all 0.3s ease;
    }

    .tab-btn:hover {
      color: var(--accent-color);
      background: rgba(56, 189, 248, 0.05);
    }

    .tab-btn.active {
      color: #ffffff;
      background: rgba(56, 189, 248, 0.2);
      border-bottom: 2px solid var(--accent-color);
    }

    .copy-btn {
      background: rgba(56, 189, 248, 0.1);
      border: 1px solid rgba(56, 189, 248, 0.2);
      color: var(--accent-color);
      font-family: 'Outfit', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      cursor: pointer;
      padding: 0.35rem 0.75rem;
      border-radius: 0.35rem;
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .copy-btn:hover {
      background: rgba(56, 189, 248, 0.2);
      border-color: var(--accent-color);
      color: #ffffff;
      box-shadow: 0 0 8px rgba(56, 189, 248, 0.3);
    }

    .copy-btn:active {
      transform: scale(0.95);
    }

    .wasm-panel {
      display: none;
    }

    .wasm-panel.active {
      display: flex;
    }

    footer {
      text-align: center;
      margin-top: 5rem;
      color: var(--secondary-color);
      font-size: 0.9rem;
    }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Performance Report</h1>
      <p class="subtitle">Flutter Web Application Profiling Results</p>
    </header>

    <div class="grid">
      <!-- Frame Health -->
      <div class="card">
        <h2>Frame Health</h2>
        <div class="metric">
          <span class="metric-label">Average Frame Interval</span>
          <span class="metric-value">{{frameHealth.avgIntervalMs}} ms</span>
        </div>
        <div class="metric">
          <span class="metric-label">Average Frame Work</span>
          <span class="metric-value danger">{{frameHealth.avgWorkMs}} ms</span>
        </div>
        <div class="metric">
          <span class="metric-label">Drop Rate</span>
          <span class="metric-value danger">{{frameHealth.dropRate}}%</span>
        </div>
        <div class="metric">
          <span class="metric-label">Requested Frames</span>
          <span class="metric-value">{{frameHealth.requestedCount}}</span>
        </div>
        <div class="metric">
          <span class="metric-label">Processed Frames</span>
          <span class="metric-value">{{frameHealth.processedCount}}</span>
        </div>
      </div>

      <!-- Time Breakdown -->
      <div class="card">
        <h2>Time Breakdown <span style="font-size: 0.9rem; color: var(--secondary-color); font-weight: normal; margin-left: 0.75rem;">(Scale: 0% to {{chartScale}}% CPU budget)</span></h2>
        <div class="bar-chart">
          {{#timeBreakdown}}
          <span class="bar-label" title="{{category}}">{{category}}</span>
          <div class="bar-container">
            <div class="bar" style="width: {{displayWidth}}%">
              {{#hasPercentVal}}<span class="bar-percent">{{percent}}%</span>{{/hasPercentVal}}
            </div>
          </div>
          <span class="metric-value">{{durationMs}} ms</span>
          {{/timeBreakdown}}
        </div>
      </div>
    </div>

    <!-- Hot Functions -->
    <div class="card" style="width: 100%;">
      <h2>Top 10 Hot Functions</h2>
      <table>
        <thead>
          <tr>
            <th style="width: 5%;">#</th>
            <th style="width: 40%;">Function</th>
            <th style="width: 35%;">Location</th>
            <th style="width: 10%;">Est. CPU</th>
            <th style="width: 10%;">Samples / %</th>
          </tr>
        </thead>
        <tbody>
          {{#hotFunctions}}
          <tr>
            <td style="{{#hasWasm}}border-bottom: none;{{/hasWasm}}">{{index}}</td>
            <td class="mono" style="{{#hasWasm}}border-bottom: none;{{/hasWasm}}">{{name}}</td>
            <td style="{{#hasWasm}}border-bottom: none;{{/hasWasm}}">
              <span class="{{tagClass}}">{{tagText}}</span> 
              {{#hasGithubUrl}}
              <a href="{{githubUrl}}" target="_blank" style="color: var(--accent-color); text-decoration: none; border-bottom: 1px dashed var(--accent-color);">{{url}}</a>
              {{/hasGithubUrl}}
              {{^hasGithubUrl}}
              {{url}}
              {{/hasGithubUrl}}
            </td>
            <td class="mono" style="{{#hasWasm}}border-bottom: none;{{/hasWasm}}">{{estimatedMs}} ms</td>
            <td class="mono" style="{{#hasWasm}}border-bottom: none;{{/hasWasm}}">
              {{samples}} <span style="color: var(--secondary-color); font-size: 0.75rem; font-weight: normal;">({{percent}}%)</span>
            </td>
          </tr>
          {{#hasWasm}}
          <tr>
            <td></td>
            <td colspan="4" style="padding-top: 0; padding-bottom: 1.5rem;">
              <details style="cursor: pointer;">
                <summary style="color: var(--accent-color); font-size: 0.8rem; margin-bottom: 0.75rem;">View Wasm Instructions</summary>
                
                {{#hasWasmAnalysis}}
                {{#wasmAnalysis.hasWarnings}}
                <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 0.5rem; padding: 0.75rem 1rem; margin-bottom: 1rem; font-size: 0.85rem; color: var(--text-color); line-height: 1.4; display: flex; align-items: center; gap: 0.5rem;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                  <span>
                    <strong>Allocation Churn/Verification Warnings:</strong> 
                    Statically scanned <strong>{{wasmAnalysis.totalInstructions}} instructions</strong>.
                    {{#wasmAnalysis.hasAllocationCount}}
                    Heap allocated <strong>{{wasmAnalysis.allocationCount}} structures</strong> (struct.new / array.new).
                    {{/wasmAnalysis.hasAllocationCount}}
                    {{#wasmAnalysis.hasTypeCheckCount}}
                    Executed <strong>{{wasmAnalysis.typeCheckCount}} dynamic casts</strong> (ref.cast / ref.test).
                    {{/wasmAnalysis.hasTypeCheckCount}}
                  </span>
                </div>
                {{/wasmAnalysis.hasWarnings}}
                {{^wasmAnalysis.hasWarnings}}
                <div style="background: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.2); border-radius: 0.5rem; padding: 0.75rem 1rem; margin-bottom: 1rem; font-size: 0.85rem; color: var(--text-color); line-height: 1.4; display: flex; align-items: center; gap: 0.5rem;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                  <span>
                    <strong>Clean Wasm path:</strong> Scanned <strong>{{wasmAnalysis.totalInstructions}} instructions</strong> with 0 dynamic allocations or typecasts.
                  </span>
                </div>
                {{/wasmAnalysis.hasWarnings}}
                {{/hasWasmAnalysis}}

                <div class="wasm-tabs">
                  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; border-bottom: 1px solid var(--glass-border); padding-bottom: 0.25rem;">
                    <div style="display: flex; gap: 0.5rem;">
                      <button class="tab-btn active" onclick="showWasm(this, 'opt-{{index}}')">Optimized (wasm-opt)</button>
                      {{#hasWasmUnopt}}
                      <button class="tab-btn" onclick="showWasm(this, 'unopt-{{index}}')">Unoptimized (dart2wasm raw)</button>
                      {{/hasWasmUnopt}}
                    </div>
                    <button class="copy-btn" onclick="copyWasmMarkdown(this, '{{name}}', '{{index}}')">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px; vertical-align: -2px;"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                      Copy Markdown
                    </button>
                  </div>
                  
                  <div id="opt-{{index}}" class="wasm-panel active">
                    <div class="code-block" style="width: 100%;">
                      <div class="gutter">
                        {{#wasmLines}}{{number}}<br>{{/wasmLines}}
                      </div>
                      <div class="code-content">{{#wasmLines}}{{#isBad}}<span style="background: rgba(239, 68, 68, 0.2); display: inline-block; width: 100%; font-weight: 600; color: #fca5a5;">{{text}}</span>{{/isBad}}{{^isBad}}{{text}}{{/isBad}}
{{/wasmLines}}</div>
                    </div>
                  </div>
                  
                  {{#hasWasmUnopt}}
                  <div id="unopt-{{index}}" class="wasm-panel" style="display: none;">
                    <div class="code-block" style="width: 100%;">
                      <div class="gutter">
                        {{#wasmUnoptLines}}{{number}}<br>{{/wasmUnoptLines}}
                      </div>
                      <div class="code-content">{{#wasmUnoptLines}}{{#isBad}}<span style="background: rgba(239, 68, 68, 0.2); display: inline-block; width: 100%; font-weight: 600; color: #fca5a5;">{{text}}</span>{{/isBad}}{{^isBad}}{{text}}{{/isBad}}
{{/wasmUnoptLines}}</div>
                    </div>
                  </div>
                  {{/hasWasmUnopt}}
                </div>
              </details>
            </td>
          </tr>
          {{/hasWasm}}
          {{/hotFunctions}}
        </tbody>
      </table>
    </div>

    <footer>
      Generated by flutter_web_perf tool.
    </footer>
  </div>

  <script>
    function showWasm(btn, panelId) {
      const tabsContainer = btn.closest('.wasm-tabs');
      if (!tabsContainer) return;
      
      const buttons = tabsContainer.querySelectorAll('.tab-btn');
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      const panels = tabsContainer.querySelectorAll('.wasm-panel');
      panels.forEach(p => {
        p.style.display = 'none';
        p.classList.remove('active');
      });
      
      const targetPanel = document.getElementById(panelId);
      if (targetPanel) {
        targetPanel.style.display = 'flex';
        targetPanel.classList.add('active');
      }
    }

    function copyWasmMarkdown(btn, funcName, index) {
      const optDiv = document.querySelector('#opt-' + index + ' .code-content');
      const unoptDiv = document.querySelector('#unopt-' + index + ' .code-content');
      
      const optWat = optDiv ? optDiv.textContent.trim() : '';
      const unoptWat = unoptDiv ? unoptDiv.textContent.trim() : '';
      
      let md = '### Hot Function: `' + funcName + '` disassemblies\n\n';
      
      if (optWat) {
        md += '#### Optimized (wasm-opt)\n';
        md += '```wat\n' + optWat + '\n```\n\n';
      }
      
      if (unoptWat) {
        md += '#### Unoptimized (dart2wasm raw)\n';
        md += '```wat\n' + unoptWat + '\n```\n';
      } else {
        md += '*(No unoptimized raw disassembly available)*\n';
      }
      
      navigator.clipboard.writeText(md).then(() => {
        const originalHTML = btn.innerHTML;
        
        btn.style.background = 'rgba(34, 197, 94, 0.2)';
        btn.style.borderColor = '#22c55e';
        btn.style.color = '#ffffff';
        btn.innerHTML = `
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px; vertical-align: -2px;"><polyline points="20 6 9 17 4 12"></polyline></svg>
          Copied!
        `;
        
        setTimeout(() => {
          btn.style.background = '';
          btn.style.borderColor = '';
          btn.style.color = '';
          btn.innerHTML = originalHTML;
        }, 2000);
      }).catch(err => {
        alert('Failed to copy markdown to clipboard: ' + err);
      });
    }
  </script>
</body>
</html>
